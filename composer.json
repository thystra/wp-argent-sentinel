{
  "name": "argent-sentinel/wordpress-connector",
  "description": "WordPress event producer and account-verification connector for Argent Sentinel",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "phpunit/phpunit": "^9.6",
    "squizlabs/php_codesniffer": "^3.13.5",
    "wp-coding-standards/wpcs": "^3.4"
  },
  "autoload": {
    "psr-4": {
      "ArgentSentinel\\WordPress\\": "src/"
    }
  },
  "scripts": {
    "test": "php tests/run.php",
    "lint:php": "phpcs"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "sort-packages": true
  }
}
